generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum GallerySourceType {
  official
  community
}

enum GalleryVisibility {
  public
}

enum GalleryItemStatus {
  draft
  pending_review
  published
  rejected
  offline
}

model GalleryAuthor {
  id        String       @id
  name      String
  avatarUrl String?
  items     GalleryItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryAsset {
  id             String   @id
  type           String
  url            String
  thumbUrl       String?
  mimeType       String
  width          Int?
  height         Int?
  size           Int?
  checksum       String?
  coverForItem   GalleryItem? @relation("CoverAssetRelation")
  previewForItem GalleryItem? @relation("PreviewAssetRelation")
  sourceForItem  GalleryItem? @relation("SourceAssetRelation")
  exportForItem  GalleryItem? @relation("ExportAssetRelation")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model GalleryPatternDetail {
  id                 String       @id @default(cuid())
  itemId             String       @unique
  width              Int
  height             Int
  beadCount          Int
  paletteCount       Int
  colorStatsJson     Json
  configJson         Json
  patternPayloadJson Json
  sourceMetadataJson Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  item               GalleryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model GalleryItem {
  id             String             @id
  title          String
  description    String?
  sourceType     GallerySourceType   @default(community)
  visibility     GalleryVisibility   @default(public)
  status         GalleryItemStatus   @default(published)
  authorId       String
  author         GalleryAuthor       @relation(fields: [authorId], references: [id])
  coverAssetId   String @unique
  coverAsset     GalleryAsset        @relation("CoverAssetRelation", fields: [coverAssetId], references: [id])
  previewAssetId String @unique
  previewAsset   GalleryAsset        @relation("PreviewAssetRelation", fields: [previewAssetId], references: [id])
  sourceAssetId  String? @unique
  sourceAsset    GalleryAsset?       @relation("SourceAssetRelation", fields: [sourceAssetId], references: [id])
  exportAssetId  String? @unique
  exportAsset    GalleryAsset?       @relation("ExportAssetRelation", fields: [exportAssetId], references: [id])
  patternDetail  GalleryPatternDetail?
  style          String
  brand          String
  canvasSize     Int
  tagsJson       Json
  viewCount      Int                @default(0)
  likeCount      Int                @default(0)
  favoriteCount  Int                @default(0)
  downloadCount  Int                @default(0)
  shareCount     Int                @default(0)
  hotScore       Int                @default(0)
  coverWidth     Int?
  coverHeight    Int?
  sortWeight     Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  publishedAt    DateTime?

  @@index([publishedAt])
  @@index([sortWeight])
  @@index([hotScore])
}
