    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "prisma": "^7.8.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
