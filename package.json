{
  "name": "dodoudou-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server/gallery-server.mjs",
    "dev": "vite",
    "prebuild": "prisma generate",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc -b --pretty false",
    "color-system:build": "node scripts/build-color-system.mjs",
    "color-system:validate": "node scripts/validate-color-system.mjs",
    "gallery:server": "node server/gallery-server.mjs",
    "gallery:clear": "node scripts/clear-gallery-data.mjs",
    "gallery:export": "node scripts/export-gallery-data.mjs",
    "gallery:import": "node scripts/import-gallery-data.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma generate && prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node server/seed-gallery.mjs"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.1",
    "resend": "^6.12.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "prisma": "^7.8.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
